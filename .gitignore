# Generated TLS certificates (created at runtime by setup.sh)
/tmp/wazuh-certs/
configs/compose/certs/*.pem

# Mode state file (written by setup.sh, read by teardown/access/status)
.wazuh-mode

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# Shell history / temp files
*.log
*.tmp
